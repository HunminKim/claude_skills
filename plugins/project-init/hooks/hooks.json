{
  "description": "project-init plugin hooks — verifier 결과 감지 후 문서 자동 업데이트",
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/update_docs.py",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
